    "text_muted": "#8B6914",
    "accent": "#7A5C14",
    "accent_light": "#B8941E",
    "accent_glow": "rgba(122, 92, 20, 0.3)",
    "border": "rgba(122, 92, 20, 0.15)",
    "border_strong": "rgba(122, 92, 20, 0.3)",
    "yes": "#7A1515",
    "no": "#1A2E4A"
