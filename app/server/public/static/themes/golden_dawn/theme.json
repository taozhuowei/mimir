{
  "id": "golden_dawn",
  "name": "Golden Dawn",
  "description": "Classic Hermetic Order of the Golden Dawn tarot theme",
  "fonts": {
    "display": {
      "family": "Cinzel",
      "weights": {
        "400": "fonts/cinzel-400.woff2",
        "600": "fonts/cinzel-600.woff2",
        "700": "fonts/cinzel-700.woff2"
      }
    },
    "body": {
      "family": "LXGW WenKai",
      "weights": {
        "300": "fonts/lxgw-wenkai-light.subset.woff2",
        "400": "fonts/lxgw-wenkai-regular.subset.woff2"
      }
    }
  },
  "ui": {
    "btn_primary": "ui/btn_primary.svg",
    "icon_wands": "ui/icon-wands.png",
    "icon_wands_inactive": "ui/icon-wands-inactive.png",
    "icon_swords": "ui/icon-swords.png",
    "icon_swords_inactive": "ui/icon-swords-inactive.png",
    "icon_cups": "ui/icon-cups.png",
    "icon_cups_inactive": "ui/icon-cups-inactive.png",
    "icon_pentacles": "ui/icon-pentacles.png",
    "icon_pentacles_inactive": "ui/icon-pentacles-inactive.png",
    "icon_settings": "ui/icon-settings.svg"
