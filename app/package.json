{
  "name": "scales-tarot-app",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev:h5": "uni",
    "build:h5": "uni build",
    "dev:mp-weixin": "node ../node_modules/@dcloudio/vite-plugin-uni/bin/uni.js -p mp-weixin",
    "build:mp-weixin": "node ../node_modules/@dcloudio/vite-plugin-uni/bin/uni.js build -p mp-weixin",
    "dev:server": "tsx ../server/src/server.ts",
    "start": "concurrently -n server,h5 --prefix-colors cyan,yellow \"npm run dev:server\" \"npm run dev:h5\"",
    "test:unit": "vitest run",
    "type-check": "vue-tsc --noEmit"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0"
  }
}
