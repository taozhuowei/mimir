{
  "name": "scales-tarot",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "vue-tsc --noEmit -p app/tsconfig.json && tsc --noEmit -p server/tsconfig.json && concurrently --kill-others-on-fail -n h5,mp \"cross-env UNI_INPUT_DIR=app/src VITE_ROOT_DIR=app node node_modules/@dcloudio/vite-plugin-uni/bin/uni.js build --config app/vite.config.ts\" \"cross-env UNI_INPUT_DIR=app/src VITE_ROOT_DIR=app node node_modules/@dcloudio/vite-plugin-uni/bin/uni.js build -p mp-weixin --config app/vite.config.ts\" && tsx server/src/server.ts"
  },
  "workspaces": [
    "app",
    "server",
    "test"
  ],
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-4080420251103001",
    "@dcloudio/uni-app-plus": "3.0.0-4080420251103001",
    "@dcloudio/uni-components": "3.0.0-4080420251103001",
    "@dcloudio/uni-h5": "3.0.0-4080420251103001",
    "express": "^4.18.2",
    "gsap": "^3.14.2",
    "pinia": "^3.0.4",
    "vue": "3.4.21"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.8",
    "@dcloudio/uni-automator": "3.0.0-4080420251103001",
    "@dcloudio/uni-cli-shared": "3.0.0-4080420251103001",
    "@dcloudio/uni-mp-weixin": "^3.0.0-4080420251103001",
    "@dcloudio/uni-stacktracey": "3.0.0-4080420251103001",
    "@dcloudio/vite-plugin-uni": "3.0.0-4080420251103001",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/supertest": "^7.2.0",
    "@vue/runtime-core": "3.4.21",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.1.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "jsdom": "^29.0.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
