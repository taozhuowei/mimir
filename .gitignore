# Build outputs
/dist/
/app/server/dist/

# Playwright screenshot artifacts: viewport_smoke.spec.ts writes
# home-/result-*.png here (cwd-relative), separate from the config's
# dist/ outputDir. Regenerated every e2e run, never tracked.
/test-results/

# Dependencies
node_modules/

# Local env overrides (.env.development.local is generated by `yarn dev`;
# .env.production.local must be created by hand before deployment).
.env*.local

# Per-developer Claude Code overrides (the shared settings file is
# .claude/settings.json; .local.json is the personal override slot).
/.claude/settings.local.json

# Yarn 4 (Berry) — node-modules linker, Corepack-managed (no committed release)
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/sdks
!.yarn/versions
.pnp.*
