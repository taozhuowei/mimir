{
  "threshold": 0.13,
  "minLines": 5,
  "minTokens": 50,
  "reporters": ["console"],
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/test/**",
    "**/static/**",
    "app/frontend/src/**/*.json",
    "app/frontend/src/**/*.d.ts"
  ],
  "format": ["typescript", "vue", "javascript"],
  "absolute": false,
  "noSymlinks": true,
  "gitignore": true
}
